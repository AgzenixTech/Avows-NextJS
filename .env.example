# ---------------------------------------------------------------------------
# Avows contact form backend configuration
# Copy this file to `.env.local` (dev) or set these in your hosting provider.
# Everything here EXCEPT NEXT_PUBLIC_* is server-only and never sent to the UI.
# ---------------------------------------------------------------------------

# --- PostgreSQL ------------------------------------------------------------
# Option A: single connection string
DATABASE_URL=postgresql://avows:password@localhost:5432/avows
# Option B: discrete variables (used only if DATABASE_URL is not set)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=avows
# PGPASSWORD=password
# PGDATABASE=avows
# Set to "true" for managed Postgres (RDS, Supabase, Neon, etc.)
PGSSL=false

# --- Amazon SES (email) ----------------------------------------------------
AWS_REGION=ap-southeast-1
# Omit the access keys to use an IAM role / instance profile (recommended in AWS).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# "From" must be a verified SES identity. "Name <email>" format is supported.
SES_FROM_EMAIL=AVOWS Website <no-reply@avowstech.com>
# Where contact submissions are delivered.
SES_TO_EMAIL=info@avowstech.com
# Optional: fixed reply-to (defaults to the visitor's email if unset).
# SES_REPLY_TO_EMAIL=info@avowstech.com
# Optional: SES configuration set for dedicated IPs / event tracking.
# SES_CONFIGURATION_SET=

# --- Google reCAPTCHA v2 (checkbox) ---------------------------------------
# Public site key (safe to expose). Defaults to the original avowstech.com key.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeOj5csAAAAALcIdHUIU_NT8bGLtFnEz5xhGE4N
# Secret key — server-only. Verification is skipped if this is empty (dev only).
RECAPTCHA_SECRET_KEY=

# --- Rate limiting (DDoS / abuse protection) -------------------------------
# Shared across all forms (contact, homepage, partner, career).
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=600000
